NODE_ENV=test 
APP_NAME=
APP_PORT=3001
APP_URL=http://localhost:3001

# =====================
# FRONTEND CONFIG
# =====================
FRONTEND_URL=http://localhost:5500

# Database
DATABASE_URL="postgresql://postgres:1234@postgres:5432/test" # docker
DB_HOST=postgres
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=test

# =====================
# JWT
# =====================
JWT_REFRESH_SECRET=refresh-token-secret
JWT_REFRESH_EXPIRE=7d
JWT_ACCESS_SECRET=access-token-secret
JWT_ACCESS_EXPIRE=1h

# =====================
# LOGGING
# =====================
LOG_LEVEL=debug

# =====================
# Cookies
# =====================
HTTPONLY_COOKIES=true
SECURE_COOKIES=false
SAMESITE_COOKIES=lax
PATH_COOKIES=/

# =====================
# CORS
# =====================
CORS_ORIGIN=

# =====================
# REDIS
# =====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=1234
REDIS_DB=1

# =====================
# others 
# =====================