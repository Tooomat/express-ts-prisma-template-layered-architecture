# =====================
# APP CONFIG
# =====================
NODE_ENV=development
APP_NAME=
APP_PORT=3000
APP_URL=http://localhost:3000

# =====================
# FRONTEND CONFIG
# =====================
FRONTEND_URL=http://localhost:5500

# =====================
# DATABASE
# =====================
DATABASE_URL="postgresql://postgres:1234@localhost:5432/serba?connect_timeout=30&idle_timeout=30" # local

DB_HOST=localhost # local
DB_USER=postgres
DB_PORT=5432
DB_PASSWORD=1234
DB_NAME=serba

# =====================
# JWT
# =====================
JWT_REFRESH_SECRET=refresh-token-secret
JWT_REFRESH_EXPIRE=7d
JWT_ACCESS_SECRET=access-token-secret
JWT_ACCESS_EXPIRE=1h

# =====================
# LOGGING
# =====================
LOG_LEVEL=debug

# =====================
# Cookies
# =====================
HTTPONLY_COOKIES=true
SECURE_COOKIES=false
SAMESITE_COOKIES=lax
PATH_COOKIES=/

# =====================
# CORS
# =====================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# =====================
# REDIS
# =====================
REDIS_HOST=localhost # local
REDIS_PORT=6379
REDIS_PASSWORD=1234
REDIS_DB=0

# =====================
# others 
# =====================